# =============================================================================
# Valura AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# --- LLM (required) ---
# Used by the intent classifier.
GEMINI_API_KEY=AIza...

# Model to use. gemini-3-flash-preview is recommended.
GEMINI_MODEL=gemini-3-flash-preview

# --- Application ---
APP_ENV=development              # development | production | test

# =============================================================================
# Optional — only set what you actually use
# =============================================================================

# --- Persistence ---
# Leave blank to use in-memory session store (default for assignment).
DATABASE_URL=

# --- Cache backend ---
# Leave blank to use in-memory caching.
REDIS_URL=